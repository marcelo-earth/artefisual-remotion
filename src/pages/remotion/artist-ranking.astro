---
import { Icon } from "astro-icon/components";
import DomainRedirect from "~/components/domain-redirect.astro";
import artefisualIcon from "~/assets/artefisual-icon.svg";
import "@fontsource/plus-jakarta-sans/400.css";
import "@fontsource/plus-jakarta-sans/500.css";
import "@fontsource/plus-jakarta-sans/600.css";
import "@fontsource/plus-jakarta-sans/700.css";
import "~/styles/index.css";

const title = "Mi top 5 de artista | Artefisual";
---

<!DOCTYPE html>
<html lang="es" class="h-full" data-theme="dark">
  <head>
    <DomainRedirect />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <script is:inline>
      const theme = localStorage.getItem("theme") || "system";
      if (theme === "system") {
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme = prefersDark ? "dark" : "light";
      } else {
        document.documentElement.dataset.theme = theme;
      }
    </script>
    <style>
      [data-theme="dark"] { color-scheme: dark; }
      [data-theme="light"] { color-scheme: light; }
    </style>
  </head>
  <body class="min-h-screen bg-default text-default font-sans">
    <header class="fixed top-0 inset-x-0 z-50 border-b border-offset bg-default/97 backdrop-blur-md">
      <div class="max-w-2xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/remotion" class="flex items-center gap-2 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none rounded" aria-label="Ver todos los tests">
          <img src={artefisualIcon.src} alt="Logo de Artefisual" class="w-[36px] object-cover invert-on-dark" width="36" height="36" />
          <Icon name="artefisual" class="h-6 w-auto invert-on-dark select-none" aria-hidden="true" />
        </a>
        <button
          id="profile-btn"
          type="button"
          aria-label="Cambiar tu nombre"
          class="flex items-center gap-2 rounded-full border border-offset px-3 py-1.5 text-base text-offset hover:bg-offset/40 hover:text-default focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition"
        >
          <Icon name="tabler:user" class="size-4 shrink-0" aria-hidden="true" />
          <span id="profile-label">Tu nombre</span>
        </button>
      </div>
    </header>

    <dialog
      id="name-dialog"
      class="m-auto w-full max-w-sm rounded-2xl border border-offset bg-default p-6 text-default shadow-2xl backdrop:bg-black/60 backdrop:backdrop-blur-sm"
    >
      <h2 class="font-bold text-lg mb-1">¿Cómo te llamas?</h2>
      <p class="text-base text-offset mb-4">Algunos videos usarán tu nombre.</p>
      <form id="name-form" method="dialog">
        <input
          id="name-input"
          type="text"
          placeholder="Escribe tu nombre..."
          maxlength="30"
          autocomplete="given-name"
          class="w-full rounded-xl border border-offset bg-offset/30 px-4 py-3 text-base text-default placeholder:text-offset/60 focus:outline-none focus:ring-2 focus:ring-primary transition mb-4"
        />
        <div class="flex gap-2 justify-end">
          <button
            type="button"
            id="name-cancel"
            class="px-4 py-2 rounded-lg border border-offset text-base text-offset hover:bg-offset/40 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition"
          >
            Cancelar
          </button>
          <button
            type="submit"
            class="px-4 py-2 rounded-lg bg-primary text-white text-base font-semibold hover:opacity-90 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition"
          >
            Guardar
          </button>
        </div>
      </form>
    </dialog>

    <script>
      const KEY = "remotion:user-name";
      const btn = document.getElementById("profile-btn")!;
      const label = document.getElementById("profile-label")!;
      const dialog = document.getElementById("name-dialog") as HTMLDialogElement;
      const input = document.getElementById("name-input") as HTMLInputElement;
      const cancelBtn = document.getElementById("name-cancel")!;
      const form = document.getElementById("name-form")!;

      function updateLabel(name: string) {
        label.textContent = name || "Tu nombre";
      }

      updateLabel(localStorage.getItem(KEY) || "");

      btn.addEventListener("click", () => {
        input.value = localStorage.getItem(KEY) || "";
        dialog.showModal();
        requestAnimationFrame(() => input.focus());
      });

      cancelBtn.addEventListener("click", () => dialog.close());

      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const name = input.value.trim();
        if (name) {
          localStorage.setItem(KEY, name);
        } else {
          localStorage.removeItem(KEY);
        }
        updateLabel(name);
        dialog.close();
      });

      dialog.addEventListener("click", (e) => {
        if (e.target === dialog) dialog.close();
      });
    </script>

    <main class="max-w-2xl mx-auto px-4 pt-24 pb-6">
      <a href="/remotion" class="inline-flex items-center gap-1 text-base text-offset hover:text-default focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none rounded transition mb-6">
        <Icon name="tabler:chevron-left" class="size-4" aria-hidden="true" />
        Tests
      </a>

      <!-- Paso 1: buscar artista -->
      <div id="step-search">
        <h1 class="text-2xl font-bold mb-1">🎤 Mi top 5 de artista</h1>
        <p class="text-offset text-base mb-6">Busca un artista y rankea tus 5 canciones favoritas de toda su carrera.</p>

        <form id="search-form" class="flex gap-2 mb-4" autocomplete="off">
          <input
            id="artist-input"
            type="text"
            placeholder="Artista o banda..."
            class="flex-1 px-4 py-2.5 rounded-lg border border-offset bg-default text-default placeholder:text-offset focus:outline-none focus:ring-2 focus:ring-primary text-base"
          />
          <button
            type="submit"
            class="px-5 py-2.5 rounded-lg bg-primary text-white font-semibold hover:opacity-90 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition"
          >
            Buscar
          </button>
        </form>

        <div id="search-loading" class="hidden py-4 flex justify-center">
          <div class="size-6 border-2 border-offset border-t-primary rounded-full animate-spin" aria-hidden="true"></div>
        </div>
        <p id="search-error" class="hidden text-red-400 text-base py-2" role="alert"></p>
        <div id="artist-results" class="hidden flex flex-col gap-2" role="list"></div>
      </div>

      <!-- Paso 2: elegir canciones -->
      <div id="step-tracks" class="hidden">
        <div class="flex items-center gap-3 mb-4">
          <button id="back-to-search" class="text-offset hover:text-default focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none rounded transition" aria-label="Volver a la búsqueda">
            <Icon name="tabler:chevron-left" class="size-5" aria-hidden="true" />
          </button>
          <div id="tracks-artist-name" class="font-semibold text-default text-lg"></div>
        </div>
        <p class="text-offset text-base mb-4">Elige exactamente <strong class="text-default">5</strong> canciones para rankear.</p>
        <div id="tracks-loading" class="hidden py-8 flex justify-center">
          <div class="size-6 border-2 border-offset border-t-primary rounded-full animate-spin" aria-hidden="true"></div>
        </div>
        <p id="tracks-error" class="hidden text-red-400 text-base" role="alert"></p>
        <div id="tracks-list" class="flex flex-col gap-2 pb-32" role="group" aria-label="Lista de canciones del artista"></div>
      </div>

      <!-- Paso 3: comparaciones -->
      <div id="step-compare" class="hidden">
        <p id="compare-label" class="text-offset text-base mb-2" aria-live="polite"></p>
        <h2 class="text-xl font-bold mb-6">¿Cuál prefieres?</h2>
        <div class="relative grid grid-cols-2 gap-10">
          <button
            id="compare-btn-a"
            class="rounded-xl border border-offset px-4 py-6 text-base font-semibold text-default text-center [@media(hover:hover)]:hover:bg-offset/40 [@media(hover:hover)]:hover:border-primary focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition disabled:opacity-40 disabled:cursor-not-allowed"
          ></button>
          <span
            aria-hidden="true"
            class="pointer-events-none absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-10 flex size-12 items-center justify-center rounded-full border border-offset bg-default text-base font-bold italic text-offset shadow-md ring-4 ring-default"
          >vs</span>
          <button
            id="compare-btn-b"
            class="rounded-xl border border-offset px-4 py-6 text-base font-semibold text-default text-center [@media(hover:hover)]:hover:bg-offset/40 [@media(hover:hover)]:hover:border-primary focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition disabled:opacity-40 disabled:cursor-not-allowed"
          ></button>
        </div>
      </div>

      <!-- Paso 4: resultado -->
      <div id="step-result" class="hidden">
        <div class="mb-8">
          <div id="result-artist-name" class="font-bold text-default text-xl"></div>
        </div>

        <div id="video-idle" class="flex justify-center">
          <button id="generate-video-btn" type="button" class="px-6 py-3 rounded-lg bg-primary text-white font-semibold hover:opacity-90 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:outline-none transition flex items-center justify-center gap-2 w-full sm:w-auto">
            <Icon name="tabler:sparkles" class="size-5" aria-hidden="true" />
            Generar mi video
          </button>
        </div>

        <div id="video-loading" class="hidden flex flex-col items-center gap-3 py-4" aria-live="polite">
          <div class="size-8 border-2 border-offset border-t-primary rounded-full animate-spin" aria-hidden="true"></div>
          <p class="text-offset text-base">Renderizando tu video...</p>
        </div>

        <div id="video-error" class="hidden flex flex-col items-center gap-3 py-2" role="alert">
          <p id="video-error-text" class="text-red-400 text-base"></p>
          <button id="video-retry-btn" type="button" class="px-4 py-2 rounded-lg border border-offset text-default font-medium hover:bg-offset/40 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition">Intenta de nuevo</button>
        </div>

        <div id="video-result" class="hidden flex flex-col items-center gap-3 mt-2">
          <p id="video-timing-text" class="text-offset text-base"></p>
          <video id="video-result-player" class="w-full max-w-[240px] rounded-xl" controls autoplay loop playsinline aria-label="Tu video resultado"></video>
          <div class="flex flex-col gap-2 w-full sm:flex-row sm:flex-wrap sm:justify-center sm:gap-3">
            <a id="video-download-link" href="#" download class="px-5 py-2.5 rounded-lg border border-offset text-default font-medium hover:bg-offset/40 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition flex items-center justify-center gap-2 w-full sm:w-auto">
              <Icon name="tabler:download" class="size-4" aria-hidden="true" />
              Descargar
            </a>
            <button id="video-share-instagram-btn" type="button" class="hidden px-5 py-2.5 rounded-lg text-white font-medium bg-gradient-to-br from-[#feda75] via-[#d62976] to-[#4f5bd5] hover:opacity-90 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition flex items-center justify-center gap-2 w-full sm:w-auto">
              <Icon name="tabler:brand-instagram" class="size-4" aria-hidden="true" />
              Instagram
            </button>
            <button id="video-share-tiktok-btn" type="button" class="hidden px-5 py-2.5 rounded-lg text-white font-medium bg-black hover:opacity-90 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition flex items-center justify-center gap-2 w-full sm:w-auto">
              <Icon name="tabler:brand-tiktok" class="size-4" aria-hidden="true" />
              TikTok
            </button>
            <button id="video-share-whatsapp-btn" type="button" class="hidden px-5 py-2.5 rounded-lg text-white font-medium bg-[#25D366] hover:opacity-90 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition flex items-center justify-center gap-2 w-full sm:w-auto">
              <Icon name="tabler:brand-whatsapp" class="size-4" aria-hidden="true" />
              WhatsApp
            </button>
          </div>
        </div>

        <div class="flex justify-center mt-6">
          <button id="restart-btn" type="button" class="w-full px-5 py-2.5 rounded-lg border border-offset text-default font-medium hover:bg-offset/40 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition flex items-center justify-center gap-2">
            <Icon name="tabler:refresh" class="size-4" aria-hidden="true" />
            Empezar de nuevo
          </button>
        </div>
      </div>
    </main>

    <div id="floating-confirm" class="fixed bottom-0 inset-x-0 z-40 hidden">
      <div class="pointer-events-none h-16 bg-gradient-to-t from-default to-transparent"></div>
      <div class="bg-default px-4 pb-6">
        <div class="max-w-2xl mx-auto">
          <button
            id="tracks-confirm-btn"
            disabled
            class="w-full py-3 rounded-lg bg-primary text-white font-semibold hover:opacity-90 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition disabled:opacity-40 disabled:cursor-not-allowed"
          >
            Continuar (0/5)
          </button>
        </div>
      </div>
    </div>

    <script>
      interface Artist { artistId: number; artistName: string; primaryGenreName?: string; }
      interface Track { trackId: number; trackName: string; trackNumber: number; collectionName: string; previewUrl?: string; artworkUrl100?: string; }

      const PICK_COUNT = 5;

      const stepSearch = document.getElementById("step-search")!;
      const stepTracks = document.getElementById("step-tracks")!;
      const stepCompare = document.getElementById("step-compare")!;
      const stepResult = document.getElementById("step-result")!;

      const floatingConfirm = document.getElementById("floating-confirm")!;
      new MutationObserver(() => {
        floatingConfirm.classList.toggle("hidden", stepTracks.classList.contains("hidden"));
      }).observe(stepTracks, { attributes: true, attributeFilter: ["class"] });

      const searchForm = document.getElementById("search-form") as HTMLFormElement;
      const artistInput = document.getElementById("artist-input") as HTMLInputElement;
      const searchLoading = document.getElementById("search-loading")!;
      const searchError = document.getElementById("search-error")!;
      const artistResults = document.getElementById("artist-results")!;

      const backToSearch = document.getElementById("back-to-search")!;
      const tracksArtistName = document.getElementById("tracks-artist-name")!;
      const tracksLoading = document.getElementById("tracks-loading")!;
      const tracksError = document.getElementById("tracks-error")!;
      const tracksList = document.getElementById("tracks-list")!;
      const tracksConfirmBtn = document.getElementById("tracks-confirm-btn") as HTMLButtonElement;

      const compareLabel = document.getElementById("compare-label")!;
      const compareBtnA = document.getElementById("compare-btn-a") as HTMLButtonElement;
      const compareBtnB = document.getElementById("compare-btn-b") as HTMLButtonElement;

      const resultArtistName = document.getElementById("result-artist-name")!;
      const videoIdle = document.getElementById("video-idle")!;
      const videoLoading = document.getElementById("video-loading")!;
      const videoError = document.getElementById("video-error")!;
      const videoErrorText = document.getElementById("video-error-text")!;
      const videoResult = document.getElementById("video-result")!;
      const videoTimingText = document.getElementById("video-timing-text")!;
      const generateVideoBtn = document.getElementById("generate-video-btn")!;
      const videoRetryBtn = document.getElementById("video-retry-btn")!;
      const videoPlayer = document.getElementById("video-result-player") as HTMLVideoElement;
      const videoDownloadLink = document.getElementById("video-download-link") as HTMLAnchorElement;
      const videoShareInstagramBtn = document.getElementById("video-share-instagram-btn")!;
      const videoShareTiktokBtn = document.getElementById("video-share-tiktok-btn")!;
      const videoShareWhatsappBtn = document.getElementById("video-share-whatsapp-btn")!;
      const restartBtn = document.getElementById("restart-btn")!;

      let selectedArtist: Artist | null = null;
      let selectedTracks: Track[] = [];
      let rankedSongs: string[] = [];
      let topSongPreviewUrl: string | null = null;
      let topSongArtwork: string | null = null;
      let currentBlob: Blob | null = null;

      function show(el: HTMLElement) { el.classList.remove("hidden"); }
      function hide(el: HTMLElement) { el.classList.add("hidden"); }
      function showStep(step: HTMLElement) {
        [stepSearch, stepTracks, stepCompare, stepResult].forEach(s => s.classList.add("hidden"));
        step.classList.remove("hidden");
      }

      function highRes(url: string, size = 600): string {
        return url.replace(/\d+x\d+bb/, `${size}x${size}bb`);
      }

      function proxyUrl(url: string): string {
        return `/api/proxy-image?url=${encodeURIComponent(highRes(url, 1200))}`;
      }

      // Difumina el cover en un canvas y devuelve un data URL. Hornear el blur en
      // pixeles hace que se vea en cualquier navegador (Safari no aplica
      // filter: blur() en el render client-side de Remotion).
      async function makeBlurredBackground(src: string): Promise<string | undefined> {
        try {
          const img = new Image();
          img.crossOrigin = "anonymous";
          await new Promise<void>((resolve, reject) => {
            img.onload = () => resolve();
            img.onerror = () => reject(new Error("img load failed"));
            img.src = src;
          });

          const W = 540, H = 960; // mitad de 1080x1920: suficiente para un fondo borroso
          const canvas = document.createElement("canvas");
          canvas.width = W;
          canvas.height = H;
          const ctx = canvas.getContext("2d");
          if (!ctx) return undefined;

          const scale = Math.max(W / img.width, H / img.height) * 1.3;
          const dw = img.width * scale;
          const dh = img.height * scale;
          ctx.filter = "blur(40px) brightness(0.3) saturate(1.5)";
          ctx.drawImage(img, (W - dw) / 2, (H - dh) / 2, dw, dh);

          return canvas.toDataURL("image/jpeg", 0.82);
        } catch {
          return undefined;
        }
      }

      function slugify(text: string): string {
        return text
          .normalize("NFD").replace(/[\u0300-\u036f]/g, "")
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/^-+|-+$/g, "")
          .slice(0, 60) || "artista";
      }

      function videoFileName(): string {
        const slug = selectedArtist ? slugify(selectedArtist.artistName) : "artista";
        return `top-5-${slug}-artefisual.mp4`;
      }

      async function searchArtists(term: string): Promise<Artist[]> {
        const res = await fetch(`/api/itunes?action=search&term=${encodeURIComponent(term)}&entity=musicArtist&limit=8&country=us`);
        const data = await res.json();
        return ((data.results ?? []) as any[]).filter(r => r.wrapperType === 'artist') as Artist[];
      }

      async function getArtistSongs(artistId: number): Promise<Track[]> {
        const res = await fetch(`/api/itunes?action=lookup&id=${artistId}&entity=song&limit=50&country=us`);
        const data = await res.json();
        return ((data.results ?? []) as any[])
          .filter(r => r.wrapperType === 'track' && r.kind === 'song') as Track[];
      }

      // Merge sort
      let resolveComparison: ((v: number) => void) | null = null;
      let compareCount = 0;

      function askComparison(a: Track, b: Track): Promise<number> {
        return new Promise(resolve => {
          resolveComparison = resolve;
          compareCount++;
          compareLabel.textContent = `Comparación ${compareCount}`;
          compareBtnA.textContent = a.trackName;
          compareBtnB.textContent = b.trackName;
          compareBtnA.disabled = false;
          compareBtnB.disabled = false;
          compareBtnA.focus();
        });
      }

      compareBtnA.addEventListener("click", () => {
        if (!resolveComparison) return;
        const resolve = resolveComparison;
        resolveComparison = null;
        compareBtnA.disabled = true;
        compareBtnB.disabled = true;
        resolve(-1);
      });

      compareBtnB.addEventListener("click", () => {
        if (!resolveComparison) return;
        const resolve = resolveComparison;
        resolveComparison = null;
        compareBtnA.disabled = true;
        compareBtnB.disabled = true;
        resolve(1);
      });

      async function mergeSort(arr: Track[]): Promise<Track[]> {
        if (arr.length <= 1) return [...arr];
        const mid = Math.floor(arr.length / 2);
        const left = await mergeSort(arr.slice(0, mid));
        const right = await mergeSort(arr.slice(mid));
        return mergeParts(left, right);
      }

      async function mergeParts(left: Track[], right: Track[]): Promise<Track[]> {
        const result: Track[] = [];
        let i = 0, j = 0;
        while (i < left.length && j < right.length) {
          const cmp = await askComparison(left[i], right[j]);
          if (cmp <= 0) result.push(left[i++]);
          else result.push(right[j++]);
        }
        return [...result, ...left.slice(i), ...right.slice(j)];
      }

      // Video
      async function generateVideo() {
        if (!selectedArtist) return;
        hide(videoIdle);
        hide(videoError);
        hide(videoResult);
        show(videoLoading);
        const startedAt = performance.now();
        try {
          const { renderArtistRankingVideoClientSide } = await import("~/lib/artist-ranking/render-client");
          const blurredBackground = topSongArtwork
            ? await makeBlurredBackground(proxyUrl(topSongArtwork))
            : undefined;
          const blob = await renderArtistRankingVideoClientSide({
            artistName: selectedArtist.artistName,
            songs: rankedSongs,
            previewUrl: topSongPreviewUrl || undefined,
            blurredBackground,
          });
          const elapsed = ((performance.now() - startedAt) / 1000).toFixed(2);
          currentBlob = blob;
          const blobUrl = URL.createObjectURL(blob);
          videoPlayer.src = blobUrl;
          videoDownloadLink.href = blobUrl;
          videoDownloadLink.download = videoFileName();
          const file = new File([blob], videoFileName(), { type: "video/mp4" });
          if (navigator.canShare && navigator.canShare({ files: [file] })) {
            show(videoShareInstagramBtn);
            show(videoShareTiktokBtn);
            show(videoShareWhatsappBtn);
          }
          hide(videoLoading);
          show(videoResult);
          videoTimingText.textContent = `Generado en ${elapsed}s`;
        } catch (err) {
          hide(videoLoading);
          show(videoError);
          videoErrorText.textContent = err instanceof Error ? err.message : "No se pudo generar el video.";
        }
      }

      async function shareVideo() {
        if (!currentBlob) return;
        const file = new File([currentBlob], videoFileName(), { type: "video/mp4" });
        try { await navigator.share({ files: [file], title: `Mi top 5 de ${selectedArtist?.artistName}` }); } catch { }
      }

      generateVideoBtn.addEventListener("click", generateVideo);
      videoRetryBtn.addEventListener("click", generateVideo);
      videoShareInstagramBtn.addEventListener("click", shareVideo);
      videoShareTiktokBtn.addEventListener("click", shareVideo);
      videoShareWhatsappBtn.addEventListener("click", shareVideo);

      // Paso 1: búsqueda
      searchForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const term = artistInput.value.trim();
        if (!term) return;
        hide(artistResults);
        hide(searchError);
        show(searchLoading);
        artistResults.innerHTML = "";
        try {
          const artists = await searchArtists(term);
          hide(searchLoading);
          if (artists.length === 0) {
            searchError.textContent = "No se encontraron artistas. Prueba con otro nombre.";
            show(searchError);
            return;
          }
          artists.forEach(artist => {
            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = "w-full text-left px-4 py-3 rounded-xl border border-offset hover:bg-offset/40 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition text-default text-base font-medium";
            btn.textContent = artist.artistName + (artist.primaryGenreName ? ` · ${artist.primaryGenreName}` : "");
            btn.addEventListener("click", () => selectArtist(artist));
            artistResults.appendChild(btn);
          });
          show(artistResults);
        } catch {
          hide(searchLoading);
          searchError.textContent = "Error al buscar. Revisa tu conexión e intenta de nuevo.";
          show(searchError);
        }
      });

      // Paso 2: selección de canciones
      async function selectArtist(artist: Artist) {
        selectedArtist = artist;
        selectedTracks = [];
        tracksList.innerHTML = "";
        tracksArtistName.textContent = artist.artistName;
        hide(tracksError);
        show(tracksLoading);
        showStep(stepTracks);
        updateConfirmBtn();

        try {
          const songs = await getArtistSongs(artist.artistId);
          hide(tracksLoading);
          if (songs.length === 0) {
            tracksError.textContent = "No se encontraron canciones para este artista.";
            show(tracksError);
            return;
          }
          songs.forEach(track => {
            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = "w-full flex items-center gap-3 px-4 py-3 rounded-xl border border-offset hover:bg-offset/40 focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none transition text-left";
            btn.setAttribute("aria-pressed", "false");
            btn.innerHTML = `
              <span class="text-default text-base flex-1">${track.trackName}</span>
              <span class="text-offset text-base truncate max-w-[140px]">${track.collectionName}</span>
              <span class="track-check hidden text-primary text-lg shrink-0" aria-hidden="true">♥</span>`;
            btn.addEventListener("click", () => toggleTrack(track, btn));
            tracksList.appendChild(btn);
          });
        } catch {
          hide(tracksLoading);
          tracksError.textContent = "Error al cargar canciones. Intenta de nuevo.";
          show(tracksError);
        }
      }

      backToSearch.addEventListener("click", () => showStep(stepSearch));

      function toggleTrack(track: Track, btn: HTMLButtonElement) {
        const isSelected = btn.getAttribute("aria-pressed") === "true";
        if (isSelected) {
          selectedTracks = selectedTracks.filter(t => t.trackId !== track.trackId);
          btn.setAttribute("aria-pressed", "false");
          btn.classList.remove("border-primary", "bg-primary/10");
          btn.querySelector(".track-check")?.classList.add("hidden");
        } else {
          if (selectedTracks.length >= PICK_COUNT) return;
          selectedTracks.push(track);
          btn.setAttribute("aria-pressed", "true");
          btn.classList.add("border-primary", "bg-primary/10");
          btn.querySelector(".track-check")?.classList.remove("hidden");
        }
        updateConfirmBtn();
      }

      function updateConfirmBtn() {
        const n = selectedTracks.length;
        tracksConfirmBtn.disabled = n < PICK_COUNT;
        tracksConfirmBtn.textContent = `Continuar (${n}/${PICK_COUNT})`;
      }

      tracksConfirmBtn.addEventListener("click", () => {
        compareCount = 0;
        compareBtnA.disabled = true;
        compareBtnB.disabled = true;
        showStep(stepCompare);
        mergeSort([...selectedTracks]).then(sorted => {
          rankedSongs = sorted.map(t => t.trackName);
          topSongPreviewUrl = sorted[0]?.previewUrl ?? null;
          topSongArtwork = sorted[0]?.artworkUrl100 ?? null;
          showResultStep();
        });
      });

      function showResultStep() {
        if (!selectedArtist) return;
        resultArtistName.textContent = selectedArtist.artistName;
        hide(videoIdle);
        hide(videoLoading);
        hide(videoError);
        hide(videoResult);
        show(videoIdle);
        hide(videoShareInstagramBtn);
        hide(videoShareTiktokBtn);
        hide(videoShareWhatsappBtn);
        currentBlob = null;
        showStep(stepResult);
        generateVideo();
      }

      restartBtn.addEventListener("click", () => {
        selectedArtist = null;
        selectedTracks = [];
        rankedSongs = [];
        topSongPreviewUrl = null;
        topSongArtwork = null;
        currentBlob = null;
        artistInput.value = "";
        artistResults.innerHTML = "";
        hide(artistResults);
        hide(searchError);
        showStep(stepSearch);
      });
    </script>
  <script>
      const tap = new Audio("/tap_sound.mp3");
      tap.volume = 0.5;
      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (target.closest("a, button, summary, [role='button']")) {
          tap.currentTime = 0;
          tap.play().catch(() => {});
        }
      });
    </script>
  </body>
</html>
